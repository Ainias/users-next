{
    "name": "@ainias42/users-next",
    "version": "0.1.5",
    "description": "User Management for express-app",
    "main": "dist/commonjs/users-next.js",
    "exports": {
        ".": {
            "types": "./dist/users-next.d.ts",
            "import": "./dist/users-next.js"
        },
        "./models": {
            "types": "./dist/models.d.ts",
            "import": "./dist/models.js"
        }
    },
    "type": "module",
    "scripts": {
        "build:esm": "tsc",
        "build": "ctix build && npm run build:esm",
        "update-packages": "npm run build && node bin/updateCopies.cjs",
        "typecheck": "tsc --noEmit",
        "lint:no-cache": "eslint \"src/{**/*,*}.{js,jsx,tsx,ts}\"",
        "lint": "npm run lint:no-cache -- --cache",
        "lint:fix": "npm run lint -- --fix",
        "postinstall": "npx patch-package"
    },
    "keywords": [],
    "author": "Silas Günther",
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@ainias42/config": "^1.2.0",
        "@ainias42/express-app": "^0.4.3",
        "@ainias42/js-helper": "^0.9.1",
        "@ainias42/react-bootstrap-mobile": "^1.2.0",
        "@ainias42/typeorm-helper": "^0.1.1",
        "@types/express": "^5.0.6",
        "@types/node": "^22.19.20",
        "@types/react": "^19.2.17",
        "@typescript-eslint/parser": "^8.60.1",
        "ctix": "^2.8.1",
        "eslint": "^10.4.1",
        "express": "^5.2.1",
        "patch-package": "^8.0.1",
        "react": ">=19.2.0",
        "tsc-alias": "^1.8.17",
        "typeorm": "^1.0.0",
        "typescript": "^6.0.3",
        "zustand": "^5.0.14"
    },
    "dependencies": {
        "cookie-parser": "^1.4.7",
        "jose": "^6.2.3",
        "react-hook-form": "^7.77.0",
        "yup": "^1.7.1"
    },
    "peerDependencies": {
        "@ainias42/express-app": ">=0.4.2",
        "@ainias42/js-helper": ">=0.9.0",
        "@ainias42/react-bootstrap-mobile": ">=1.1.2",
        "@ainias42/typeorm-helper": ">=0.1.0",
        "express": "^4.19.2",
        "react": ">=19.2.0",
        "typeorm": "^1.0.0",
        "zustand": "^5.0.14"
    }
}
