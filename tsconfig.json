{
    "extends": "@ainias42/config/tsconfig.json",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "noFallthroughCasesInSwitch": true,
        "typeRoots": ["node_modules/@types", "node_modules/react-bootstrap-mobile/src/types"],
        "outDir": "./dist",
        "rootDir": "./src",
        "noEmit": false,
        "declaration": true
    },
    "include": ["src/**/*"],
    "exclude": ["./test/**/*"]
}
